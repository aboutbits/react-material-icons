{
  "name": "@aboutbits/react-material-icons",
  "version": "2.0.1",
  "description": "Material design icon components for React",
  "author": "AboutBits",
  "license": "MIT",
  "homepage": "https://github.com/aboutbits/react-material-icons",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aboutbits/react-material-icons"
  },
  "bugs": {
    "url": "https://github.com/aboutbits/react-material-icons/issues"
  },
  "keywords": [
    "material design",
    "icons",
    "react"
  ],
  "private": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "main": "dist/",
  "files": [
    "readme.md",
    "dist/**/*"
  ],
  "engines": {
    "npm": ">=10",
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "clear": "rm -rf src/*",
    "generate": "node generator.js && eslint --fix src",
    "lint": "eslint --cache --ignore-pattern src",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jestconfig.json --passWithNoTests",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test && npm run lint",
    "version": "npm run test && npm run lint && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "devDependencies": {
    "@aboutbits/eslint-config": "^5.1.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "axios": "^1.6.8",
    "eslint": "^9.39.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.5",
    "react": "^19.2.7",
    "react-dom": "19.2.7",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  }
}
